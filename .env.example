# ============================================================
# MailBento 환경변수
# ============================================================
# 로컬: 이 파일을 .env.local 로 복사하고 값을 채우세요.
# 프로덕션: Synology Container Manager 환경변수에 직접 등록.

# --- 암호화 키 (32바이트 base64) ---
# 생성: openssl rand -base64 32
ENCRYPTION_KEY=

# --- DB ---
DATABASE_PATH=./data/mailbento.db

# --- Google OAuth (Gmail) ---
# https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# --- Microsoft OAuth (Outlook) ---
# https://portal.azure.com/ → Microsoft Entra ID → App registrations
# Tenant: 개인 MSA만이면 "consumers", 조직 포함이면 "common"
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/auth/microsoft/callback
# Outlook IMAP-OAuth (XOAUTH2) 용 별도 redirect URI — Entra 앱에 같이 등록 필요
MICROSOFT_IMAP_REDIRECT_URI=http://localhost:3000/api/auth/microsoft-imap/callback

# --- 앱 동작 ---
# 대시보드 자동 새로고침 간격 (초)
REFRESH_INTERVAL_SECONDS=180
# 각 박스에 보여줄 메일 개수
MESSAGES_PER_BOX=15

# --- 인증 (선택) ---
# 둘 다 비워두면 인증 비활성 (앱 그대로 공개). Tailscale 만으로 보안 충분하다면 비워둬도 OK.
# 추가 비밀번호 잠금이 필요하면 둘 다 설정.
#
# AUTH_PASSWORD: plaintext 또는 bcrypt 해시 ($2a$ / $2b$ 시작) 둘 다 자동 감지.
#   bcrypt 추천 — plaintext 는 누군가 .env.local 을 보면 그대로 노출됨.
AUTH_PASSWORD=
# AUTH_SECRET: 세션 쿠키 암호화 키 (32바이트 base64). 절대 외부 노출 금지.
#   생성: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=
